# Suivan Environment Variables
# Copy this file to .env.local and fill in your values

# Sui Network
NEXT_PUBLIC_SUI_NETWORK=testnet

# Smart Contract Package IDs (testnet)
NEXT_PUBLIC_PACKAGE_ID=0xff8500790272c409da1deddf45e46236d4d77a1a7d250ca7728a113d4fc08edf
NEXT_PUBLIC_FACTORY_ID=0xc47d988a84759e85a5386390e4eef4227bc5634c249a3493c16425ede16c1624
NEXT_PUBLIC_USDC_TYPE=0xff8500790272c409da1deddf45e46236d4d77a1a7d250ca7728a113d4fc08edf::test_usdc::TEST_USDC

# Sponsored Transaction (gasless pool joins)
# Generate: sui keytool ed25519-parse A_SUI_PRIVATE_KEY_HEX
SPONSOR_SECRET_KEY=your_ed25519_private_key_hex

# Optional: Sponsor SUI coin for gas
# Fund the sponsor address from the faucet:
# sui client faucet --address $(sui keytool --json | jq -r '.[0].suiAddress')
