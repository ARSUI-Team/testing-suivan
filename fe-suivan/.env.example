# Suivan Environment Variables
# Copy this file to .env.local and fill in your values

# Sui Network
NEXT_PUBLIC_SUI_NETWORK=testnet

# Smart Contract Package IDs (testnet)
# Deployed package: https://suiscan.xyz/testnet/package/0x72bbfae9cd90e62b1cecb9db218eb52ac6135d322d232eb5e8a35a9b1d41bb1b
NEXT_PUBLIC_PACKAGE_ID=0x72bbfae9cd90e62b1cecb9db218eb52ac6135d322d232eb5e8a35a9b1d41bb1b
NEXT_PUBLIC_FACTORY_ID=0xd45cfd2dcc4be81c17f44f3e5f934605c7d09bcf1adaeadab576607493383867
NEXT_PUBLIC_USDC_TYPE=0x72bbfae9cd90e62b1cecb9db218eb52ac6135d322d232eb5e8a35a9b1d41bb1b::test_usdc::TEST_USDC

# TreasuryCap for minting TEST_USDC
TREASURY_CAP_ID=0x63af2ef268e8ab668201807c1b8452210b43d2adfe8562bac96db8b3bfbb7e4f

# Sponsored Transaction (gasless pool joins)
# Generate a sponsor keypair:
#   1. sui keytool generate ed25519
#   2. sui client faucet --address <SPONSOR_ADDRESS>
#   3. Set the private key hex below (without 0x prefix)
SPONSOR_SECRET_KEY=your_ed25519_private_key_hex

# Optional: Sponsor SUI coin for gas (already funded from step 2 above)
