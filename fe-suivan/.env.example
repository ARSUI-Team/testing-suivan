# Suivan Environment Variables
# Copy this file to .env.local and fill in your values

# Public application URL. Keep the Vercel URL until the team owns a custom domain.
NEXT_PUBLIC_SITE_URL=https://suivan.vercel.app

# Sui Network: testnet or mainnet
NEXT_PUBLIC_SUI_NETWORK=testnet

# Active testnet deployment
NEXT_PUBLIC_PACKAGE_ID=0x14b081894ab1473c3f0440b82b6dc3204c1b29ae332ff18a585b8f1af5e0d825
NEXT_PUBLIC_FACTORY_ID=0xe2587c933fdd1f4fa4bab04655a773a23d896bab18738e0efafdc6c6f36f5558
NEXT_PUBLIC_USDC_TYPE=0x14b081894ab1473c3f0440b82b6dc3204c1b29ae332ff18a585b8f1af5e0d825::test_usdc::TEST_USDC
NEXT_PUBLIC_SUI_TYPE=0x14b081894ab1473c3f0440b82b6dc3204c1b29ae332ff18a585b8f1af5e0d825::test_sui::TEST_SUI
NEXT_PUBLIC_FAUCET_ID=0xc7ab25a1c78d708441bf311929782fc95d32a9521027d4c3f868debdcfac46b4
NEXT_PUBLIC_AGENT_ADDRESS=0xa428d031fb5b7349e0dd1f17e1f5afceca2fad163a783e76ae198b71a35511a4

# Mainnet deployment must replace PACKAGE_ID, FACTORY_ID, USDC_TYPE, and
# AGENT_ADDRESS. The build intentionally fails if any are missing or if a
# test token type is used while NEXT_PUBLIC_SUI_NETWORK=mainnet.
# Mainnet SUI defaults to 0x2::sui::SUI.

# Sponsored Transaction (gasless pool joins)
# Generate a sponsor keypair:
#   1. sui keytool generate ed25519
#   2. sui client faucet --address <SPONSOR_ADDRESS>
#   3. Set the private key hex below (without 0x prefix)
SPONSOR_SECRET_KEY=your_ed25519_private_key_hex

# Optional: Sponsor SUI coin for gas (already funded from step 2 above)
